# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment under the line if you do.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms, it may cause conflict.
#   Pipfile.lock

# poetry
#   Shared by comity, poetry.lock is preferred to be committed, but not virtualenv directories
#   poetry.lock
#   .venv

# pdm
#   Shared by PDM, .pdm-python.path is preferred not to be committed
.pdm-python.path
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

